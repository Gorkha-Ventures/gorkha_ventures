PORT=3001
NODE_ENV=development

# Neon
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=14

# Google OAuth
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
ADMIN_ALLOWED_EMAILS=founder@example.com,ops@example.com

# Client/frontends for redirects + CORS
CLIENT_URL=http://localhost:3000
PUBLIC_FRONTEND_URL=http://localhost:3002

# Cloudinary (resume uploads)
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret
